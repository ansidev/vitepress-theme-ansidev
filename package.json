{
  "name": "vitepress-theme-ansidev",
  "version": "1.0.12",
  "private": true,
  "description": "The VitePress theme for ansidev's blog",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "concurrently --kill-others \"pnpm theme:dev\" \"pnpm demo:dev\"",
    "typecheck": "pnpm -r typecheck",
    "lint:check": "pnpm biome check",
    "lint": "pnpm -r typecheck && pnpm lint:check --write",
    "theme:dev": "pnpm --filter @ansidev-oss/vitepress-theme-ansidev dev",
    "theme:build": "pnpm --filter @ansidev-oss/vitepress-theme-ansidev build",
    "demo:dev": "pnpm --filter @ansidev-oss/vitepress-theme-ansidev-demo dev",
    "demo:build": "pnpm --filter @ansidev-oss/vitepress-theme-ansidev-demo build",
    "demo:preview": "pnpm --filter @ansidev-oss/vitepress-theme-ansidev-demo preview"
  },
  "keywords": [
    "vitepress",
    "theme",
    "blog",
    "tailwindcss",
    "vue3",
    "typescript",
    "i18n",
    "dark-mode",
    "ansidev"
  ],
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "concurrently": "^9.2.1"
  },
  "pnpm": {
    "overrides": {
      "vue": "3.5.32"
    }
  }
}
